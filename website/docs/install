#!/bin/sh
# XDN CLI installer.
#
#   curl -fsSL https://xdn.cs.umass.edu/install | sh
#
# Downloads the `xdn` binary for your OS/arch from the latest GitHub release,
# verifies its SHA-256 checksum, and installs it. Inspect before running:
#
#   curl -fsSL https://xdn.cs.umass.edu/install | less
#
# Environment overrides:
#   XDN_INSTALL_DIR   where to install        (default: $HOME/.local/bin)
#   XDN_VERSION       release tag to install  (default: latest, e.g. v0.1.0)
set -eu

REPO="fadhilkurnia/xdn"
INSTALL_DIR="${XDN_INSTALL_DIR:-$HOME/.local/bin}"
VERSION="${XDN_VERSION:-latest}"

info() { printf '\033[1;34m==>\033[0m %s\n' "$1"; }
err()  { printf '\033[1;31merror:\033[0m %s\n' "$1" >&2; exit 1; }

# --- detect platform ---------------------------------------------------------
os=$(uname -s | tr '[:upper:]' '[:lower:]')
case "$os" in
  linux | darwin) ;;
  *) err "unsupported OS '$os' (the XDN CLI supports linux and macOS)" ;;
esac
arch=$(uname -m)
case "$arch" in
  x86_64 | amd64) arch=amd64 ;;
  aarch64 | arm64) arch=arm64 ;;
  *) err "unsupported architecture '$arch'" ;;
esac
asset="xdn-${os}-${arch}"

# --- pick download + checksum tools -----------------------------------------
if command -v curl >/dev/null 2>&1; then
  dl() { curl -fsSL "$1" -o "$2"; }
elif command -v wget >/dev/null 2>&1; then
  dl() { wget -qO "$2" "$1"; }
else
  err "need 'curl' or 'wget' to download"
fi
if command -v sha256sum >/dev/null 2>&1; then
  sha() { sha256sum "$1" | awk '{print $1}'; }
elif command -v shasum >/dev/null 2>&1; then
  sha() { shasum -a 256 "$1" | awk '{print $1}'; }
else
  err "need 'sha256sum' or 'shasum' to verify the download"
fi

# --- resolve release URL -----------------------------------------------------
if [ "$VERSION" = "latest" ]; then
  base="https://github.com/${REPO}/releases/latest/download"
else
  base="https://github.com/${REPO}/releases/download/${VERSION}"
fi

tmp=$(mktemp -d) || err "could not create a temp dir"
trap 'rm -rf "$tmp"' EXIT INT TERM

# --- download + verify -------------------------------------------------------
info "downloading ${asset} (${VERSION})"
dl "${base}/${asset}" "${tmp}/xdn" \
  || err "could not download ${base}/${asset} (no release/binary for ${os}/${arch}?)"
dl "${base}/SHA256SUMS" "${tmp}/SHA256SUMS" \
  || err "could not download the checksum file (${base}/SHA256SUMS)"

expected=$(awk -v f="$asset" '$2 == f {print $1}' "${tmp}/SHA256SUMS")
[ -n "$expected" ] || err "no checksum for ${asset} in SHA256SUMS"
actual=$(sha "${tmp}/xdn")
[ "$expected" = "$actual" ] || err "checksum mismatch for ${asset}
  expected: ${expected}
  actual:   ${actual}"
info "checksum verified (sha256 ${actual})"

# --- install -----------------------------------------------------------------
mkdir -p "$INSTALL_DIR" 2>/dev/null \
  || err "cannot create ${INSTALL_DIR} — set XDN_INSTALL_DIR to a writable dir"
chmod +x "${tmp}/xdn"
mv -f "${tmp}/xdn" "${INSTALL_DIR}/xdn" 2>/dev/null \
  || err "cannot write to ${INSTALL_DIR} — set XDN_INSTALL_DIR or re-run with sudo"
info "installed: ${INSTALL_DIR}/xdn"

# --- PATH hint ---------------------------------------------------------------
case ":${PATH}:" in
  *":${INSTALL_DIR}:"*) ;;
  *) printf '\n%s is not on your PATH. Add it (and restart your shell):\n  export PATH="%s:$PATH"\n' \
       "$INSTALL_DIR" "$INSTALL_DIR" ;;
esac
printf '\nDone. Get started:\n  xdn --help\n'
